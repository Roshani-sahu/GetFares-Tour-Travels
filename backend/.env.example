NODE_ENV=development
APP_NAME=travel-crm
APP_VERSION=1.0.0
PORT=3000
CORS_ORIGIN=*

JWT_ACCESS_SECRET=replace-with-minimum-16-chars-secret
JWT_ACCESS_EXPIRES_IN=15m

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_crm

LOG_LEVEL=info
HEALTH_DB_TIMEOUT_MS=2000
SHUTDOWN_TIMEOUT_MS=10000
METRICS_ENABLED=true
METRICS_TOKEN=
