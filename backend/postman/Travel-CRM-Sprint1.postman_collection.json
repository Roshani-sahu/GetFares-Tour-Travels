    },
    {
      "name": "04 - RBAC",
      "item": [
        {
          "name": "My Permissions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/me/permissions",
              "host": ["{{baseUrl}}"],
